{% extends 'base.html.twig' %}

{% block title %}{{ 'spirit.title'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('spirit') }}
    {{ encore_entry_link_tags('ai-model-selector') }}
{% endblock %}

{% block body %}
<div class="container mt-4">
    <input type="hidden" id="spirit-id" value="{{ spiritId is defined ? spiritId : '' }}">
    
    {# Block 1: Spirit Info Header - full width, 3 cols #}
    <div class="row mb-4">
        <div class="col-12">
            <div class="card__glass-panel">
                <div class="card-body p-4">
                    <div id="spirit-loading" class="text-center py-3">
                        <div class="spinner-border text-primary spinner-border-sm" role="status">
                            <span class="visually-hidden">{{ 'ui.loading'|trans }}</span>
                        </div>
                        <p class="mt-2 mb-0 small">{{ 'spirit.detail.connecting'|trans }}</p>
                    </div>
                    
                    <div id="spirit-sidebar-info" class="d-none">
                        <div class="row align-items-center">
                            <div class="col-md-4 col-lg-3 text-center mb-3 mb-md-0">
                                <div class="spirit-avatar-container big mx-auto">
                                    <div id="spiritChatAvatar" class="spirit-avatar d-flex align-items-center justify-content-center text-secondary cursor-pointer">
                                        <i class="mdi mdi-ghost spirit-detail-icon"></i>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-4 col-lg-5">
                                <div class="text-center text-md-start">
                                    <h3 id="spirit-name-display" class="mb-1">{{ 'spirit.name'|trans }}</h3>
                                    <div class="mb-3">
                                        <span class="badge bg-dark bg-opacity-25 text-cyber">{{ 'spirit.level'|trans }} <span id="spirit-level">1</span></span>
                                    </div>
                                    <div class="progress mb-2" style="height: 8px; max-width: 300px;">
                                        <div id="spirit-experience-bar" class="progress-bar progress-bar-striped progress-bar-animated bg-cyber" 
                                             role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" 
                                             style="width: 0%">
                                        </div>
                                    </div>
                                    <p class="small text-light mb-3">
                                        <span id="spirit-experience">0</span> / <span id="spirit-next-level">100</span> XP
                                    </p>
                                </div>
                            </div>
                            <div class="col-md-4 col-lg-4">
                                <div class="d-flex flex-wrap gap-3 justify-content-center justify-content-md-end">
                                    <button type="button" id="spirit-sidebar-chat-btn" class="btn btn-sm btn-cyber">
                                        <i class="mdi mdi-message-text me-2"></i>{{ 'spirit.sidebar.chat'|trans|default('Chat with Spirit') }}
                                    </button>
                                    <button type="button" id="newConversationBtnProfile" class="btn btn-sm btn-outline-primary" title="{{ 'spirit.chat.new_conversation'|trans }}">
                                        <i class="mdi mdi-message-plus me-2"></i>{{ 'spirit.chat.new_conversation'|trans }}
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    {# Block 2: Main Tabs - full width row #}
    <div class="row mb-4">
        <div class="col-12">
            <div class="glass-panel rounded p-4 px-2 px-sm-4 mb-5">
            <div id="spirit-container">
                <div id="spirit-display" class="d-none">
                    
                    {# Bootstrap Tabs #}
                    <ul class="nav nav-tabs cq-tabs mb-3" id="spirit-tabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active px-3 py-1" id="tab-settings" data-bs-toggle="tab" data-bs-target="#panel-settings" type="button" role="tab">
                                <i class="mdi mdi-cog me-1"></i>{{ 'spirit.tabs.settings'|trans|default('Settings') }}
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link px-3 py-1" id="tab-ai-tools" data-bs-toggle="tab" data-bs-target="#panel-ai-tools" type="button" role="tab">
                                <i class="mdi mdi-tools me-1"></i>{{ 'spirit.tabs.ai_tools'|trans|default('AI Tools') }}
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link px-3 py-1" id="tab-memory" data-bs-toggle="tab" data-bs-target="#panel-memory" type="button" role="tab">
                                <i class="mdi mdi-brain me-1"></i>{{ 'spirit.tabs.memory'|trans|default('Memory') }}
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link px-3 py-1" id="tab-conversations" data-bs-toggle="tab" data-bs-target="#panel-conversations" type="button" role="tab">
                                <i class="mdi mdi-forum me-1"></i>{{ 'spirit.tabs.conversations'|trans|default('Conversations') }}
                                {% if conversations is defined and conversations|length > 0 %}
                                    <span class="badge bg-dark bg-opacity-25 ms-1">{{ conversations|length }}</span>
                                {% endif %}
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link px-3 py-1" id="tab-activity" data-bs-toggle="tab" data-bs-target="#panel-activity" type="button" role="tab">
                                <i class="mdi mdi-pulse me-1"></i>{{ 'spirit.tabs.activity'|trans|default('Activity') }}
                            </button>
                        </li>
                    </ul>
                    
                    <div class="tab-content">
                        {# Memory Tab #}
                        <div class="tab-pane fade" id="panel-memory" role="tabpanel">
                            {# Memory Type Settings #}
                            <div class="row">
                                <div class="col-12 col-md-6 mb-3">
                                    <div class="d-flex flex-column h-100">
                                        <label for="profileMemoryTypeSelect" class="form-label mb-2">
                                            <i class="mdi mdi-memory me-1 text-cyber"></i>{{ 'spirit.memory.type'|trans|default('Spirit Memory Type') }}
                                        </label>
                                        <select class="form-select form-select-sm bg-dark bg-opacity-50 text-light border-secondary mt-2"
                                                id="profileMemoryTypeSelect" style="width: auto; min-width: 180px;">
                                            <option value="0">🚫 No Memory</option>
                                            <option value="1">🧠 Reflexes</option>
                                            <option value="2">🤖 Memory Agent</option>
                                        </select>
                                        <div id="profileMemoryTypeInfo" class="mt-2 small text-secondary"></div>
                                    </div>
                                </div>
                                <div class="col-12 col-md-6 mb-3">
                                    <label for="spirit-subconsciousness-agent-ai-model" class="form-label"><i class="mdi mdi-brain me-2 text-cyber"></i>{{ 'spirit.settings.subconsciousness_agent_ai_model'|trans|default('Memory Agent AI Model') }}</label>
                                    <input type="hidden" id="spirit-subconsciousness-agent-ai-model" value="{{ spirit.settings.subconsciousnessAgentAiModel ?? '' }}">
                                    <button type="button" class="btn btn-outline-primary w-100 text-start d-flex justify-content-between align-items-center" id="spirit-subconsciousness-agent-ai-model-selector-btn">
                                        <span id="spirit-subconsciousness-agent-ai-model-display">
                                            {% if spirit.settings.subconsciousnessAgentAiModel is defined and spirit.settings.subconsciousnessAgentAiModel %}
                                                {% for model in aiModels %}
                                                    {% if model.id == spirit.settings.subconsciousnessAgentAiModel %}
                                                        {{ model.modelName }}
                                                    {% endif %}
                                                {% endfor %}
                                            {% else %}
                                                {{ 'spirit.settings.use_primary_model'|trans|default('Use Primary AI Model') }}
                                            {% endif %}
                                        </span>
                                        <i class="mdi mdi-chevron-down"></i>
                                    </button>
                                    <div class="form-text text-muted ms-2">{{ 'spirit.settings.subconsciousness_agent_ai_model_hint'|trans|default('Model used for the Memory Agent sub-consciousness synthesis') }}</div>
                                </div>
                            </div>

                            <hr class="border-secondary border-opacity-25">

                            <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
                                <h5 class="mb-0">
                                    <i class="mdi mdi-graph text-cyber me-2"></i>{{ 'spirit.memory.title'|trans }}
                                </h5>
                                <div class="d-flex align-items-center gap-3 flex-wrap">
                                    <small class="" id="profile-memory-stats">
                                        <i class="mdi mdi-package-variant text-cyber opacity-50"></i>
                                        <span id="profile-stats-packs">0</span>x {{ 'spirit.memory.packs'|trans|default('packs') }} &nbsp; · &nbsp;
                                        <i class="mdi mdi-circle-multiple text-cyber opacity-50"></i>
                                        <span id="profile-stats-nodes">0</span>x {{ 'spirit.memory.nodes'|trans }} &nbsp; · &nbsp;
                                        <i class="mdi mdi-link-variant text-cyber opacity-50"></i>
                                        <span id="profile-stats-edges">0</span>x {{ 'spirit.memory.relationships'|trans }}
                                    </small>
                                    <a href="{{ path('cq_memory_explorer', {spirit: spiritId}) }}" class="btn btn-sm btn-outline-primary" id="btn-open-memory-explorer-tab">
                                        <i class="mdi mdi-arrow-expand-all me-1"></i>{{ 'spirit.memory.explore'|trans }}
                                    </a>
                                </div>
                            </div>
                        </div>
                            
                            {# Settings Tab #}
                            <div class="tab-pane fade show active" id="panel-settings" role="tabpanel">
                                <div class="row">
                                    <div class="col-12 col-md-6 mb-3">
                                        <label for="spirit-ai-model" class="form-label"><i class="mdi mdi-robot-outline me-2 text-cyber"></i>{{ 'spirit.settings.ai_model'|trans|default('AI Model') }}</label>
                                        <input type="hidden" id="spirit-ai-model" value="{{ spirit.settings.aiModel ?? '' }}">
                                        <button type="button" class="btn btn-outline-primary w-100 text-start d-flex justify-content-between align-items-center" id="spirit-ai-model-selector-btn">
                                            <span id="spirit-ai-model-display">
                                                {% if spirit.settings.aiModel is defined and spirit.settings.aiModel %}
                                                    {% for model in aiModels %}
                                                        {% if model.id == spirit.settings.aiModel %}
                                                            {{ model.modelName }}
                                                        {% endif %}
                                                    {% endfor %}
                                                {% else %}
                                                    {{ 'spirit.settings.use_primary_model'|trans|default('Use Primary AI Model') }}
                                                {% endif %}
                                            </span>
                                            <i class="mdi mdi-chevron-down"></i>
                                        </button>
                                        <div class="form-text text-muted ms-2">{{ 'settings.ai.models.select_hint'|trans|default('Click to compare and select the best model for your needs') }}</div>
                                    </div>
                                    <div class="col-12 col-md-6 mb-3">
                                        <label class="form-label d-flex justify-content-between align-items-center" for="spirit-temperature">
                                            <span><i class="mdi mdi-thermometer me-2 text-cyber"></i>{{ 'spirit.chat.response_temperature'|trans|default('Temperature') }}</span>
                                            <span id="spirit-temperature-value" class="badge fw-normal bg-secondary bg-opacity-25">{{ spirit.settings.temperature ?? '0.7' }}</span>
                                        </label>
                                        <input type="range" class="form-range-input w-100" id="spirit-temperature" min="0" max="1" value="{{ spirit.settings.temperature ?? '0.7' }}" step="0.1">
                                        <div class="d-flex justify-content-between small text-secondary mt-1 mx-2">
                                            <span>0 ({{ 'spirit.chat.temperature_precise'|trans|default('Precise') }})</span>
                                            <span>1 ({{ 'spirit.chat.temperature_creative'|trans|default('Creative') }})</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="form-group mb-1">
                                    <label for="spirit-system-prompt" class="form-label"><i class="mdi mdi-message-text-outline me-2 text-cyber"></i>{{ 'spirit.settings.system_prompt'|trans|default('System Prompt') }}</label>
                                    <div class="position-relative">
                                        <textarea id="spirit-system-prompt" class="form-control" rows="14"
                                            placeholder="{{ 'spirit.settings.system_prompt_placeholder'|trans|default('Define how your Spirit should behave and what knowledge it should have...') }}"
                                            oninput="let saveBtn = document.getElementById('update-spirit-settings'); saveBtn.disabled = false;"></textarea>
                                        <button type="button" id="spirit-system-prompt-add-file"
                                            class="btn btn-sm btn-outline-primary position-absolute"
                                            style="bottom: 8px; right: 8px;"
                                            title="{{ 'spirit.settings.add_file_hint'|trans|default('Pick from File Browser — file content will be injected into the system prompt') }}">
                                            <i class="mdi mdi-file-plus-outline"></i>
                                            <span class="d-none d-md-inline ms-1">{{ 'spirit.settings.add_file'|trans|default('Add file') }}</span>
                                        </button>
                                    </div>
                                    <div class="form-text text-muted p-2">{{ 'spirit.settings.system_prompt_help'|trans|default('Define your Spirit\'s character, personality, and areas of expertise.') }}</div>
                                </div>
                                <div class="d-flex justify-content-between align-items-center me-2 mt-2">
                                    <button id="open-prompt-builder" class="btn btn-sm btn-outline-secondary mx-2" type="button">
                                        <i class="mdi mdi-code-braces me-1"></i>{{ 'spirit.prompt_builder.button'|trans|default('Advanced Prompt Builder') }}
                                    </button>
                                    <button id="update-spirit-settings" class="btn btn-sm btn-cyber" disabled><i class="mdi mdi-content-save me-2"></i>{{ 'ui.save'|trans|default('Save') }}</button>
                                </div>
                            </div>
                            
                            {# AI Tools Tab #}
                            <div class="tab-pane fade" id="panel-ai-tools" role="tabpanel">
                                <div class="row">
                                    <div class="col-12 col-md-8 mb-3">
                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                            <label for="spirit-include-ai-tools" class="form-label mb-0">
                                                <i class="mdi mdi-tools text-cyber me-1"></i> {{ 'spirit.tabs.ai_tools'|trans|default('AI Tools') }}
                                            </label>
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox" role="switch" id="spirit-include-ai-tools" checked>
                                            </div>
                                        </div>
                                        <div id="spirit-ai-tools-list" class="d-flex flex-column gap-1">
                                            <div class="text-center p-3">
                                                <div class="spinner-border spinner-border-sm text-cyber" role="status"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-12 col-md-4 mb-3">
                                        <div class="d-flex align-items-center justify-content-between mb-2">
                                            <label for="spirit-ai-tools-data-optimization" class="form-label mb-0">
                                                <i class="mdi mdi-broom text-cyber me-1"></i> {{ 'spirit.chat.ai_tools_data_optimization'|trans|default('AI Tools Data Optimization') }}
                                            </label>
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input" type="checkbox" role="switch" id="spirit-ai-tools-data-optimization">
                                            </div>
                                        </div>
                                        <div class="small">
                                            <i class="mdi mdi-information-outline me-1"></i>
                                            {{ 'spirit.chat.ai_tools_data_optimization_info'|trans|default('Replaces outdated tool call data from previous turns with a placeholder before sending to AI. Keeps tool-call structure intact. Reduces tokens & context noise when Spirit re-reads/updates files.') }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            {# Activity Tab #}
                            <div class="tab-pane fade" id="panel-activity" role="tabpanel">
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="mb-0"><i class="mdi mdi-pulse text-cyber me-2"></i>{{ 'spirit.spirit_detail.interactions'|trans }}</h5>
                                </div>
                                <div id="spirit-interactions" class="rounded">
                                    {% if interactions is defined and interactions|length > 0 %}
                                        <ul class="list-group list-group-flush bg-dark bg-opacity-25 rounded">
                                            {% for interaction in interactions %}
                                                <li class="list-group-item bg-transparent border-secondary border-opacity-25">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div>
                                                            <small class="badge bg-success bg-opacity-50">+{{ interaction.experienceGained }} XP</small>
                                                        </div>
                                                        <div>
                                                            <span class="badge bg-secondary bg-opacity-50 me-2">{{ interaction.type }}</span>
                                                            {% if interaction.context %}
                                                                <small class="text-muted">{{ interaction.context }}</small>
                                                            {% endif %}
                                                        </div>
                                                        <div class="text-end">
                                                            <small class="text-muted" style="font-size: xx-small;">{{ interaction.createdAt }}</small>
                                                        </div>
                                                    </div>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% else %}
                                        <p class="text-muted small">{{ 'spirit.no_interactions'|trans }}</p>
                                    {% endif %}
                                </div>
                            </div>
                            
                            {# Conversations Tab #}
                            <div class="tab-pane fade" id="panel-conversations" role="tabpanel">
                                <div id="conversations-list" class="rounded">
                                    {% if conversations is defined and conversations|length > 0 %}
                                        <ul class="list-group list-group-flush bg-dark bg-opacity-50 rounded">
                                            {% for conversation in conversations %}
                                                <li class="list-group-item bg-transparent border-secondary border-opacity-25 cursor-pointer conversation-item" data-conversation-id="{{ conversation.id }}">
                                                    <div class="d-flex justify-content-between align-items-center">
                                                        <div class="w-100">
                                                            <i class="mdi mdi-message-outline me-2 text-cyber"></i><strong>{{ conversation.title }}</strong>
                                                            <br>
                                                            <small class="text-muted">{{ conversation.messagesCount }} {{ 'spirit.messages'|trans|default('messages') }}</small>
                                                            <small class="text-muted float-end">{{ conversation.lastInteraction }}</small>
                                                        </div>
                                                    </div>
                                                </li>
                                            {% endfor %}
                                        </ul>
                                    {% else %}
                                        <p class="text-muted small">{{ 'spirit.no_conversations'|trans|default('No conversations yet') }}</p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    {# Block 3: Spirits List - full width row, original UX/UI #}
    {% include 'spirits/_spirit_list.html.twig' with { allSpirits: allSpirits, currentSpiritId: spiritId } %}
</div>

<div data-translations="{{ {}
    |merge({'spirit.no_interactions': 'No interactions recorded yet.'|trans})
    |merge({'error.loading_spirit': 'Failed to load spirit'|trans})
    |merge({'error.creating_spirit': 'Failed to create spirit'|trans})
    |merge({'error.interaction_failed': 'Failed to interact with spirit'|trans})
    |merge({'error.loading_interactions': 'Failed to load interactions'|trans})
    |merge({'spirit.prompt_builder.saved': 'Configuration saved successfully'|trans})
    |merge({'spirit.temperature_saved': 'Temperature saved'|trans})
    |merge({'error.saving_temperature': 'Failed to save temperature'|trans})
    |merge({'error.loading_prompt': 'Failed to load prompt data'|trans})
    |merge({'error.saving_config': 'Failed to save configuration'|trans})
    |merge({'ui.saving': 'Saving...'|trans})
    |merge({'ui.save': 'Save'|trans})
    |merge({'ui.cancel': 'ui.cancel'|trans|default('Cancel')})
    |merge({'ui.close': 'ui.close'|trans|default('Close')})
    |merge({'ui.copied': 'Copied to clipboard'|trans})
    |merge({'error.copy_failed': 'Failed to copy to clipboard'|trans})
    |merge({'spirit.prompt_builder.no_tools': 'No AI tools available'|trans})
    |merge({'ai_tools.settings.saved': 'ai_tools.settings.saved'|trans|default('Settings saved')})
    |merge({'ai_tools.settings.error': 'ai_tools.settings.error'|trans|default('Failed to save settings')})
    |merge({'ai_tools.settings.no_tools': 'ai_tools.settings.no_tools'|trans|default('No AI tools available')})
    |merge({'ai_tools.settings.tool_settings': 'ai_tools.settings.tool_settings'|trans|default('Tool Settings')})
    |merge({'ai_tools.settings.no_settings': 'ai_tools.settings.no_settings'|trans|default('No configurable settings for this tool')})
    |merge({'ai_tools.settings.parameters': 'ai_tools.settings.parameters'|trans|default('Parameters')})
    |merge({'ai_tools.settings.required': 'ai_tools.settings.required'|trans|default('required')})
    |merge({'ai_tools.settings.select_model': 'ai_tools.settings.select_model'|trans|default('Select Model')})
    |merge({'ai_tools.settings.default_model': 'ai_tools.settings.default_model'|trans|default('Default (auto)')})
    |merge({'ai_tools.category.file': 'ai_tools.category.file'|trans|default('File Management')})
    |merge({'ai_tools.category.web': 'ai_tools.category.web'|trans|default('Web Tools')})
    |merge({'ai_tools.category.image': 'ai_tools.category.image'|trans|default('Image Generation')})
    |merge({'ai_tools.category.memory': 'ai_tools.category.memory'|trans|default('Memory')})
    |merge({'ai_tools.category.profile': 'ai_tools.category.profile'|trans|default('Profile')})
    |merge({'ai_tools.category.development': 'ai_tools.category.development'|trans|default('Development')})
    |merge({'ai_tools.category.spirit': 'ai_tools.category.spirit'|trans|default('Spirit')})
    |merge({'ai_tools.category.utility': 'ai_tools.category.utility'|trans|default('Utility')})
    |merge({'ai_tools.category.general': 'ai_tools.category.general'|trans|default('General')})
    |json_encode|e('html_attr') }}">
</div>

{# System Prompt Builder Modal #}
{% include 'spirit/_system_prompt_builder_modal.html.twig' %}

{# AI Model Selector Modal #}
{% include 'components/_ai_model_selector.html.twig' %}

{# Tool Settings Modal #}
<div class="modal modal-lg fade" id="spiritToolSettingsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content glass-panel">
            <div class="modal-header bg-cyber-g border-success">
                <h5 class="modal-title" id="spiritToolSettingsModalTitle">
                    <i class="mdi mdi-cog me-2"></i>{{ 'ai_tools.settings.tool_settings'|trans|default('Tool Settings') }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.close'|trans|default('Close') }}"></button>
            </div>
            <div class="modal-body" id="spiritToolSettingsModalBody">
                {# Dynamic content rendered by JS #}
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="mdi mdi-close me-2"></i>{{ 'ui.cancel'|trans|default('Cancel') }}
                </button>
                <button type="button" class="btn btn-cyber" id="spirit-btn-save-tool-settings">
                    <span class="spinner-border spinner-border-sm d-none me-1" role="status"></span>
                    <i class="mdi mdi-check me-2"></i>{{ 'ui.save'|trans|default('Save') }}
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('spirit') }}
    {{ encore_entry_script_tags('spirits') }}
    {{ encore_entry_script_tags('ai-model-selector') }}
    <script>
        // Initialize AI Model Selector for Spirit
        document.addEventListener('DOMContentLoaded', function() {
            const spiritModelBtn = document.getElementById('spirit-ai-model-selector-btn');
            const saveBtn = document.getElementById('update-spirit-settings');

            if (spiritModelBtn) {
                spiritModelBtn.addEventListener('click', function() {
                    const currentModelId = document.getElementById('spirit-ai-model').value;
                    window.aiModelSelector.open('primary', function(model) {
                        // Update hidden input
                        document.getElementById('spirit-ai-model').value = model.id;
                        // Update display
                        const displayText = model.modelName || '{{ 'spirit.settings.use_primary_model'|trans|default('Use Primary AI Model') }}';
                        document.getElementById('spirit-ai-model-display').textContent = displayText;
                        // Auto-save immediately (like Memory Type does)
                        if (window.spiritManager) {
                            window.spiritManager.updateSpiritSettings();
                        } else if (saveBtn) {
                            saveBtn.disabled = false;
                        }
                    }, currentModelId || null);
                });
            }

            const subAgentModelBtn = document.getElementById('spirit-subconsciousness-agent-ai-model-selector-btn');
            if (subAgentModelBtn) {
                subAgentModelBtn.addEventListener('click', function() {
                    const currentModelId = document.getElementById('spirit-subconsciousness-agent-ai-model').value;
                    window.aiModelSelector.open('primary', function(model) {
                        // Update hidden input
                        document.getElementById('spirit-subconsciousness-agent-ai-model').value = model.id;
                        // Update display
                        const displayText = model.modelName || '{{ 'spirit.settings.use_primary_model'|trans|default('Use Primary AI Model') }}';
                        document.getElementById('spirit-subconsciousness-agent-ai-model-display').textContent = displayText;
                        // Auto-save immediately
                        if (window.spiritManager) {
                            window.spiritManager.updateSpiritSettings();
                        } else if (saveBtn) {
                            saveBtn.disabled = false;
                        }
                    }, currentModelId || null);
                });
            }
        });
    </script>
{% endblock %}
