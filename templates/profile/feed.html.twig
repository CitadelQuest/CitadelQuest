{% extends 'base-public.html.twig' %}

{% block html_attributes %} lang="{{ profile_locale|default('en') }}"{% if profile_theme is defined and profile_theme %} data-theme="{{ profile_theme }}"{% endif %}{% endblock %}

{% block title %}{{ feed.title }} — {{ profile_username }} @ {{ profile_domain }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% if profile_custom_bg is defined and profile_custom_bg %}
    <style>
        .citadel-background::before {
            background-image: url('{{ path('cq_profile_background', {username: profile_username}) }}') !important;
        }
    </style>
    {% endif %}
    {% if profile_bg_overlay is defined and not profile_bg_overlay %}
    <style>
        .citadel-background::after {
            background-color: transparent !important;
        }
    </style>
    {% endif %}
{% endblock %}

{% block body %}
<div class="container mt-4 mb-5">

    {# Feed header card #}
    <div class="card glass-panel mb-4">
        <div class="card-body p-4">
            <div class="d-flex align-items-center flex-column flex-sm-row">
                {% if profile_has_photo %}
                <a href="{{ path('cq_profile_public', {username: profile_username}) }}" class="flex-shrink-0 me-0 me-sm-3">
                    <img src="{{ path('cq_profile_photo', {username: profile_username}) }}"
                         alt="{{ profile_username }}"
                         class="rounded"
                         style="width: 72px; height: 72px; object-fit: cover;">
                </a>
                {% endif %}
                <div class="flex-grow-1">
                    <i class="mdi mdi-rss me-2 opacity-75" title="CQ Feed"></i>
                    <h1 class="h4 mb-0">
                        {{ feed.title }}
                    </h1>
                    <small class="text-light opacity-50">
                        {{ profile_username }} · {{ profile_domain }}
                        {% if feed.description %}
                            · {{ feed.description }}
                        {% endif %}
                    </small>
                </div>
                <div class="flex-shrink-0 ms-3 text-end">
                    <span class="badge bg-secondary bg-opacity-25 text-light">
                        {{ total }} {{ total == 1 ? 'post' : 'posts' }}
                    </span>
                </div>
            </div>

            {# Other public feeds nav #}
            {% if profile_feeds|default([])|length > 1 %}
            <div class="d-flex align-items-center flex-wrap gap-2 mt-3 pt-3 border-top border-secondary border-opacity-25">
                {% for f in profile_feeds %}
                {% set isActive = f.id == feed.id %}
                <a href="{{ path('cq_profile_public_feed', {username: profile_username, feedSlug: f.feed_url_slug}) }}"
                   class="badge {{ isActive ? 'bg-success bg-opacity-25 text-cyber' : 'bg-secondary bg-opacity-10 text-secondary' }} text-decoration-none px-2 py-1" style="font-size: 0.75rem;">
                    <i class="mdi mdi-rss me-1"></i>{{ f.title }}
                </a>
                {% endfor %}
            </div>
            {% endif %}
        </div>
    </div>

    {# Posts list #}
    {% if posts|length == 0 %}
        <div class="text-center py-5 text-light opacity-50">
            <i class="mdi mdi-newspaper-variant-outline" style="font-size: 3rem;"></i>
            <p class="mt-2">{{ 'feed.no_posts'|trans }}</p>
        </div>
    {% else %}
        <div class="d-flex flex-column gap-3">
            {% for post in posts %}
            <div class="card glass-panel" id="post-{{ post.post_url_slug }}">
                <div class="card-body p-4 pb-2">
                    {# Post content #}
                    <div class="mb-2" style="word-break: break-word; overflow-wrap: break-word;">
                        {{ post.content|markdown_to_html }}
                    </div>

                    {# Attachments #}
                    {% if post.attachments is defined and post.attachments|length > 0 %}
                    <div class="mb-2">
                        {% for att in post.attachments %}
                            {% set displayStyle = att.display_style|default(att.share_display_style|default(1)) %}
                            {% set fileName = att.file_name|default(att.share_title|default('Attachment')) %}
                            {% set mimeType = att.file_mime_type|default('') %}
                            {% set isImage = mimeType[:6] == 'image/' %}
                            {% set shareUrl = att.share_url|default('') %}

                            {% if displayStyle == 0 %}
                                {# Header only #}
                                <div class="d-flex align-items-center gap-2 p-2 rounded mb-1" style="background: rgba(0,0,0,0.3);">
                                    <i class="mdi {{ isImage ? 'mdi-image' : 'mdi-file' }} text-cyber small"></i>
                                    <span class="small text-light opacity-75">{{ fileName }}</span>
                                </div>
                            {% elseif (displayStyle == 1 or displayStyle == 2) and isImage and shareUrl %}
                                {# Image preview/full via public share URL #}
                                {% set maxH = displayStyle == 1 ? '250px' : '500px' %}
                                {% set maxW = displayStyle == 1 ? 'max-width: 300px;' : '' %}
                                <div class="mb-1 rounded overflow-hidden" style="background: rgba(0,0,0,0.3); {{ maxW }}">
                                    <img src="{{ path('cq_share_access', {username: profile_username, shareUrl: shareUrl}) }}"
                                         alt="{{ fileName }}"
                                         class="img-fluid rounded"
                                         style="max-height: {{ maxH }}; object-fit: contain; width: 100%;"
                                         loading="lazy">
                                </div>
                            {% else %}
                                {# Fallback header #}
                                <div class="d-flex align-items-center gap-2 p-2 rounded mb-1" style="background: rgba(0,0,0,0.3);">
                                    <i class="mdi {{ isImage ? 'mdi-image' : 'mdi-file' }} text-cyber small"></i>
                                    <span class="small text-light opacity-75">{{ fileName }}</span>
                                    {% if shareUrl %}
                                    <a href="{{ path('cq_share_access', {username: profile_username, shareUrl: shareUrl}) }}" target="_blank" class="text-cyber text-decoration-none small ms-auto">
                                        <i class="mdi mdi-open-in-new me-1"></i>View
                                    </a>
                                    {% endif %}
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    {% endif %}

                    {# Stats bar: likes, dislikes, comments count #}
                    {% set stats = post.parsed_stats|default({likes: 0, dislikes: 0, comments: 0}) %}
                    <a href="{{ path('cq_profile_public_feed_post', {username: profile_username, feedSlug: feed.feed_url_slug, postSlug: post.post_url_slug}) }}" class="d-block align-items-center gap-1 text-decoration-none w-100" _style="margin-left: auto;">
                        <div class="d-flex align-items-center gap-3 pt-2 border-top border-secondary border-opacity-10" style="font-size:0.7rem !important;">
                            <span class="text-light opacity-50 flex-grow-1">
                                <i class="mdi mdi-clock-outline me-1"></i>{{ post.created_at|date('j M Y, H:i') }}
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <i class="mdi mdi-heart {{ stats.likes > 0 ? 'text-danger opacity-75' : 'text-secondary' }}"></i>
                                {% if stats.likes > 0 %}<span class="text-light opacity-50">{{ stats.likes }}</span>{% endif %}
                            </span>
                            <span class="d-flex align-items-center gap-1">
                                <i class="mdi mdi-thumb-down text-secondary"></i>
                                {% if stats.dislikes > 0 %}<span class="text-light opacity-50">{{ stats.dislikes }}</span>{% endif %}
                            </span>
                            <span class="d-flex align-items-center gap-1">
                            <i class="mdi mdi-chat-outline text-secondary"></i>
                            {% if stats.comments > 0 %}<span class="text-light opacity-50">{{ stats.comments }}</span>{% endif %}
                            </span>
                        </div>
                    </a>

                    {# Read-only comments #}
                    {% if post.comments_list is defined and post.comments_list|length > 0 %}
                    <div class="mt-2 pt-1">
                        {% for comment in post.comments_list %}
                            {% set cUrl = comment.cq_contact_url|default('') %}
                            {% set cName = cUrl ? cUrl|split('/')|last : 'Unknown' %}
                            {% set cDomain = cUrl ? cUrl|replace({'https://': ''})|split('/')|first : '' %}
                            <div class="d-flex gap-2 py-1 border-0 border-secondary border-opacity-10">
                                {# <div class="rounded flex-shrink-0 overflow-hidden d-flex align-items-center justify-content-center" style="width: 25px; height: 25px; background: rgba(149,236,134,0.05);">
                                    <i class="mdi mdi-account text-cyber" style="font-size: 0.7rem;"></i>
                                </div> #}
                                <div class="rounded mt-1 flex-shrink-0 overflow-hidden d-flex align-items-center justify-content-center" style="width: 24px; height: 24px; background: rgba(149,236,134,0.05);">
                                    <img src="{{ cUrl }}/photo?icon=1" alt="{{ cName }}" style="width: 100%; height: 100%; object-fit: cover;">
                                </div>
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <div class="d-flex align-items-sm-center gap-1 small flex-column flex-sm-row">
                                        <div style="min-width: 0; line-height: 0.9rem;">
                                            <span class="fw-bold text-light">{{ cName }}</span>
                                            <span class="text-light opacity-50">{{ cDomain }}</span>
                                        </div>
                                        <span class="text-muted" style="font-size: 0.7rem;">{{ comment.created_at|date('j M, H:i') }}</span>
                                    </div>
                                    <div class="text-light pb-1" style="font-size: 0.9rem; word-break: break-word;">{{ comment.content }}</div>
                                    {# Replies #}
                                    {% if comment.replies is defined and comment.replies|length > 0 %}
                                        {% for reply in comment.replies %}
                                            {% set rUrl = reply.cq_contact_url|default('') %}
                                            {% set rName = rUrl ? rUrl|split('/')|last : 'Unknown' %}
                                            {% set rDomain = rUrl ? rUrl|replace({'https://': ''})|split('/')|first : '' %}
                                            <div class="d-flex gap-2 py-1 border-0 border-secondary border-opacity-10">
                                                {# <div class="rounded flex-shrink-0 overflow-hidden d-flex align-items-center justify-content-center" style="width: 20px; height: 20px; background: rgba(149,236,134,0.05);">
                                                    <i class="mdi mdi-account text-cyber" style="font-size: 0.6rem;"></i>
                                                </div> #}
                                                <div class="rounded mt-1 flex-shrink-0 overflow-hidden d-flex align-items-center justify-content-center" style="width: 20px; height: 20px; background: rgba(149,236,134,0.05);">
                                                    <img src="{{ rUrl }}/photo?icon=1" alt="{{ rName }}" style="width: 100%; height: 100%; object-fit: cover;">
                                                </div>
                                                <div class="flex-grow-1" style="min-width: 0;">
                                                    <div class="d-flex align-items-sm-center gap-1 small flex-column flex-sm-row">
                                                        <span class="fw-bold text-light">{{ rName }}</span>
                                                        <span class="text-light opacity-50">{{ rDomain }}</span>
                                                        <span class="text-muted" style="font-size: 0.7rem;">{{ reply.created_at|date('j M, H:i') }}</span>
                                                    </div>
                                                    <div class="text-light" style="font-size: 0.85rem; word-break: break-word;">{{ reply.content }}</div>
                                                </div>
                                            </div>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if has_more or page > 1 %}
        <div class="d-flex justify-content-between align-items-center mt-4">
            {% if page > 1 %}
                <a href="{{ path('cq_profile_public_feed', {username: profile_username, feedSlug: feed.feed_url_slug, page: page - 1}) }}"
                   class="btn btn-sm btn-outline-secondary">
                    <i class="mdi mdi-chevron-left me-1"></i>{{ 'ui.previous'|trans({}, 'messages', profile_locale|default('en')) }}
                </a>
            {% else %}
                <div></div>
            {% endif %}

            <small class="text-light opacity-50">
                {{ 'ui.page'|trans({}, 'messages', profile_locale|default('en')) }} {{ page }}
            </small>

            {% if has_more %}
                <a href="{{ path('cq_profile_public_feed', {username: profile_username, feedSlug: feed.feed_url_slug, page: page + 1}) }}"
                   class="btn btn-sm btn-outline-secondary">
                    {{ 'ui.next'|trans({}, 'messages', profile_locale|default('en')) }}<i class="mdi mdi-chevron-right ms-1"></i>
                </a>
            {% else %}
                <div></div>
            {% endif %}
        </div>
        {% endif %}
    {% endif %}

</div>
{% endblock %}
