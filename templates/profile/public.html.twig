{% extends 'base-public.html.twig' %}

{% block html_attributes %} lang="{{ profile_locale|default('en') }}"{% if profile_theme is defined and profile_theme %} data-theme="{{ profile_theme }}"{% endif %}{% endblock %}

{% block title %}{{ profile_username }} @ {{ profile_domain }} — {{ 'app.name'|trans }}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% if profile_custom_bg is defined and profile_custom_bg %}
    <style>
        .citadel-background::before {
            background-image: url('{{ path('cq_profile_background', {username: profile_username}) }}') !important;
        }
    </style>
    {% endif %}
    {% if profile_bg_overlay is defined and not profile_bg_overlay %}
    <style>
        .citadel-background::after {
            background-color: transparent !important;
        }
    </style>
    {% endif %}
{% endblock %}

{# ================================================================ #}
{# Macro: share content preview (image / PDF / HTML / text / graph) #}
{# ================================================================ #}
{% macro share_preview(share, ds, username) %}
    {% if share.preview_type == 'image' %}
    <div>
        <img src="{{ share.preview_url }}" alt="{{ share.title|default(share.share_title|default('')) }}"
             class="rounded w-100" style="{% if ds == 1 %}max-height: 500px; object-fit: contain; {% endif %}background: rgba(0,0,0,0.2);">
    </div>
    {% endif %}

    {% if share.preview_type == 'pdf' %}
    <div class="rounded" style="background: rgba(0,0,0,0.2);">
        <iframe src="{{ share.preview_url }}" class="w-100 rounded border-0"
                style="{% if ds == 1 %}height: 500px;{% else %}height: 90vh;{% endif %}"></iframe>
    </div>
    {% endif %}

    {% if share.preview_type == 'html' %}
    {% if ds == 1 %}
    <div class="p-3 rounded share-preview-scroll" style="background: rgba(0,0,0,0.2); max-height: 300px; overflow-y: auto;">
        <pre class="mb-0 text-light small" style="white-space: pre-wrap; word-break: break-word;">{{ share.preview_content }}</pre>
    </div>
    {% elseif ds == 2 %}
    <div class="rounded" style="background: rgba(0,0,0,0.1);">
        {{ share.preview_content|raw }}
    </div>
    {% endif %}
    {% endif %}

    {% if share.preview_type == 'text' %}
    <div class="p-3 rounded share-preview-scroll" style="background: rgba(0,0,0,0.2);{% if ds == 1 %} max-height: 300px; overflow-y: auto;{% endif %}">
        {% if share.preview_ext in ['md', 'markdown'] %}
            <div class="text-light small">{{ share.preview_content|markdown_to_html }}</div>
        {% else %}
            <pre class="mb-0 text-light small" style="white-space: pre-wrap; word-break: break-word;">{{ share.preview_content }}</pre>
        {% endif %}
    </div>
    {% endif %}

    {% if share.preview_type == 'graph' %}
    <div>
        <div class="share-graph-preview memory-graph-preview rounded"
             data-graph-url="{{ share.preview_graph_url }}"
             style="height: 250px; background: rgba(10, 10, 15, 0.6); position: relative;">
            <div class="graph-loading position-absolute top-50 start-50 translate-middle text-center" style="z-index: 10;">
                <div class="spinner-border spinner-border-sm text-cyber" role="status">
                    <span class="visually-hidden">{{ 'ui.loading'|trans }}</span>
                </div>
            </div>
            <canvas class="rounded" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></canvas>
        </div>
        <div class="d-flex justify-content-center align-items-center mt-2 share-graph-stats">
            <small class="text-secondary">
                <i class="mdi mdi-circle-multiple text-cyber opacity-25"></i>
                <span class="stat-nodes">0</span>x {{ 'spirit.memory.nodes'|trans }} &nbsp; · &nbsp;
                <i class="mdi mdi-link-variant text-cyber opacity-25"></i>
                <span class="stat-edges">0</span>x {{ 'spirit.memory.relationships'|trans }}
            </small>
        </div>
    </div>
    {% endif %}
{% endmacro %}

{% block body %}
<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">

            {# Profile Header #}
            <div class="card glass-panel mb-3">
                <div class="card-body p-4">
                    {# Top row: Photo + (desktop: text) + Spirits #}
                    <div class="d-flex align-items-start">
                        {# Profile Photo #}
                        <div class="me-4 mb-3 flex-shrink-0">
                            {% if profile_has_photo %}
                                <a href="#" data-bs-toggle="modal" data-bs-target="#profilePhotoModal" style="cursor: pointer;">
                                <img src="{{ path('cq_profile_photo', {username: profile_username}) }}" 
                                     alt="{{ profile_username }}" 
                                     class="rounded border_ border-0 border-primary_border-opacity-50"
                                     style="width: 125px; height: 125px; object-fit: cover;">
                                </a>
                            {% else %}
                                <div class="rounded border border-2 border-secondary d-flex align-items-center justify-content-center"
                                     style="width: 125px; height: 125px; background: rgba(255,255,255,0.05);">
                                    <i class="mdi mdi-account text-cyber opacity-75" style="font-size: 48px;"></i>
                                </div>
                            {% endif %}
                        </div>

                        {# Username & Domain & Bio — desktop only (inline with photo) #}
                        <div class="flex-grow-1 d-none d-md-block">
                            <a href="{{ app.request.schemeAndHttpHost }}/{{ profile_username }}"><h2 class="h2 mb-1 mt-2 text-cyber fw-bold">{{ profile_username }}</h2></a>
                            <small class="text-light d-inline-flex align-items-center">
                                <img src="{{ asset('build/images/favicon-16x16.png') }}" title="Citadel" class="me-1" />
                                <span class="opacity-50">{{ app.request.schemeAndHttpHost }}/{{ profile_username }}</span>
                                <button class="ms-1 btn btn-sm btn-outline-primary border-0 copy-profile-url"
                                        data-url="{{ app.request.schemeAndHttpHost }}/{{ profile_username }}"
                                        title="{{ 'citadel_explorer.copy_link'|trans }}">
                                    <i class="mdi mdi-link-variant opacity-75"></i>
                                </button>
                            </small>
                        </div>

                        {# Spirit Showcase — all screen sizes, right side #}
                        <div class="ms-auto ms-md-3 flex-shrink-0">

                            {# Public Feed Badges — right side, below spirits #}
                            {% if profile_feeds|default([])|length > 0 %}
                            <div class="d-flex flex-column align-items-end gap-1 ms-auto mb-2">
                                <i class="mdi mdi-rss text-primary opacity-75" style="font-size: 1.2rem;"></i>
                                {% for feed in profile_feeds %}
                                <a href="{{ path('cq_profile_public_feed', {username: profile_username, feedSlug: feed.feed_url_slug}) }}"
                                    class="badge bg-primary bg-opacity-10 text-light opacity-75 text-decoration-none px-2 py-1" style="font-size: 0.75rem;">
                                    <i class="mdi mdi-rss me-1 text-primary opacity-75"></i>{{ feed.title }}
                                </a>
                                {% endfor %}
                            </div>
                            {% endif %}
                        {% if profile_spirits|length > 0 %}
                        <hr class="border-0 border-bottom border-1 border-secondary border-opacity-50"/>
                            {% for spirit in profile_spirits %}
                            <div class="d-flex align-items-center mb-1 mt-2" style="white-space: nowrap;">
                                <div class="rounded-circle d-flex align-items-center justify-content-center me-2"
                                     style="width: 28px; height: 28px; background: {{ spirit.color }}21;">
                                    <i class="mdi mdi-ghost" style="color: {{ spirit.color }}; font-size: 14px;"></i>
                                </div>
                                <div>
                                    <div class="small fw-bold text-light" style="line-height: 1.2;">
                                        {{ spirit.name }}
                                        {% if spirit.isPrimary and profile_spirits|length > 1 %}<i class="mdi mdi-star text-warning" style="font-size: 0.65rem;"></i>{% endif %}
                                    </div>
                                    <div class="text-light opacity-50" style="font-size: 0.65rem; line-height: 1;">{{ 'spirit.level'|trans }} {{ spirit.level }} | {{ spirit.experience }} XP</div>
                                </div>
                            </div>
                            {% endfor %}
                        {% endif %}
                        </div>
                    </div>

                    {# Username & Domain & Bio — mobile only (below photo+spirits row) #}
                    <div class="d-md-none mt-3">
                        <a href="{{ app.request.schemeAndHttpHost }}/{{ profile_username }}"><h2 class="h3 mb-1 text-cyber fw-bold">{{ profile_username }}</h2></a>
                        <small class="text-light d-inline-flex align-items-center">
                            <img src="{{ asset('build/images/favicon-16x16.png') }}" title="Citadel" class="me-1" />
                            <span class="opacity-50">{{ app.request.schemeAndHttpHost }}/{{ profile_username }}</span>
                            <button class="ms-1 btn btn-sm btn-outline-primary border-0 copy-profile-url"
                                    data-url="{{ app.request.schemeAndHttpHost }}/{{ profile_username }}"
                                    title="{{ 'citadel_explorer.copy_link'|trans }}">
                                <i class="mdi mdi-link-variant opacity-75"></i>
                            </button>
                        </small>
                    </div>

                    {% if profile_bio %}
                        {% if profile_bio|length > 600 %}
                            <div class="text-light mt-2 mb-0 bio-container" style="word-break: break-word;overflow-wrap: break-word;">
                                <div class="bio-short">{{ (profile_bio[:600] ~ '…')|markdown_to_html }}</div>
                                <div class="bio-full d-none">{{ profile_bio|markdown_to_html }}</div>
                                <a href="#" class="bio-toggle text-cyber small ms-1" data-show-more="{{ 'ui.show_more'|trans }}" data-show-less="{{ 'ui.show_less'|trans }}">{{ 'ui.show_more'|trans }}</a>
                            </div>
                        {% else %}
                            <div class="text-light mt-2 mb-0" style="word-break: break-word;overflow-wrap: break-word;">{{ profile_bio|markdown_to_html }}</div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>

            {# ============================================================ #}
            {# Profile Content — Navigation Panel + Active Group Content     #}
            {# ============================================================ #}
            {% if profile_show_profile_content|default(true) and profile_share_groups|default([])|length > 0 %}

            {# Navigation panel — single row with group links #}
            {% set navGroups = profile_share_groups|default([])|filter(g => g.show_in_nav and g.items|default([])|length > 0) %}
            {% if navGroups|length > 0 %}
            <div class="mb-2 px-2" id="profile-content-nav">
                <div class="card-body">
                    <div class="d-flex align-items-center flex-wrap gap-2">
                        {% for group in navGroups %}
                        {% set isActive = profile_active_group is not null and group.id == profile_active_group.id %}
                        {% set groupUrl = path('cq_profile_public_group', {username: profile_username, groupSlug: group.url_slug|default(group.id)}) %}
                        <a href="{{ groupUrl }}" class="text-decoration-none mb-2">
                            <span class="glass-panel {{ isActive ? 'bg-success bg-opacity-25' : '' }} py-2 px-3" style="font-size: 0.85rem;">
                                <i class="mdi {{ group.mdi_icon|default('mdi-folder') }} me-1" style="color: {{ group.icon_color|default('#95ec86') }};"></i>
                                <span class="{{ isActive ? 'text-cyber' : 'text-light opacity-75' }}">{{ group.title }}</span>
                            </span>
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

            {# Active group content #}
            {% if profile_active_group is not null and profile_active_group.items|default([])|length > 0 %}
            {% set group = profile_active_group %}
            <div class="card glass-panel mb-4" id="share-group-{{ group.id }}">
                <div class="card-header bg-transparent border-success border-1 border-bottom p-3">
                    <div class="mb-0">
                        <i class="mdi {{ group.mdi_icon|default('mdi-folder') }} me-2" style="color: {{ group.icon_color|default('#95ec86') }};"></i>
                        <span class="text-cyber">{{ group.title }}</span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush bg-transparent">
                        {% for item in group.items %}
                        {% set share = item %}
                        {% set showHeader = item.show_header|default(1) %}
                        {% set ds = item.effective_display_style|default(item.share_display_style|default(1)) %}
                        {% set desc = item.description|default('') %}
                        {% set dds = item.effective_description_display_style|default(item.share_description_display_style|default(1)) %}
                        <div class="list-group-item bg-transparent border-0 px-4 py-3">
                            {% if showHeader %}
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <a href="{{ path('cq_share_access', {username: profile_username, shareUrl: item.share_url}) }}"
                                   class="text-decoration-none">
                                    {% if item.source_type == 'cqmpack' %}
                                        <i class="mdi mdi-graph me-2 text-info"></i>
                                    {% elseif item.preview_type is defined and item.preview_type == 'pdf' %}
                                        <i class="mdi mdi-file-pdf-box me-2 text-danger"></i>
                                    {% else %}
                                        <i class="mdi mdi-file me-2 text-warning"></i>
                                    {% endif %}
                                    <span class="text-light fw-bold">{{ item.share_title }}</span>
                                    {% if item.source_type == 'cqmpack' %}
                                        <span class="badge bg-info bg-opacity-25 text-info ms-2">{{ 'cq_contact.detail.memory_pack'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-warning bg-opacity-25 text-warning ms-2">{{ 'cq_contact.detail.file'|trans }}</span>
                                    {% endif %}
                                </a>
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-light opacity-50"><i class="mdi mdi-eye me-1"></i>{{ item.views }} {{ 'cq_contact.detail.views'|trans }}</small>
                                    <button class="btn btn-sm btn-outline-primary border-0 copy-share-url"
                                            data-url="{{ app.request.schemeAndHttpHost }}/{{ profile_username }}/share/{{ item.share_url }}"
                                            title="{{ 'citadel_explorer.copy_link'|trans }}">
                                        <i class="mdi mdi-link-variant"></i>
                                    </button>
                                </div>
                            </div>
                            {% endif %}

                            {# Profile Content groups always show previews (independent from show_share_content toggle) #}
                            {% set hasPreview = share.preview_type is defined and ds > 0 %}
                            {% set hasDesc = desc|trim is not empty %}

                            {% if hasDesc or hasPreview %}
                            {% set isColumn = dds == 2 or dds == 3 %}
                            <div class="{% if showHeader %}mt-3{% endif %}{% if isColumn and hasDesc and hasPreview %} d-flex flex-column flex-md-row gap-3{% endif %}">
                                {% if hasDesc and (dds == 0 or dds == 2) %}
                                <div class="{% if isColumn and hasPreview %}flex-shrink-0{% endif %} text-light small mb-{% if not isColumn %}3{% else %}0{% endif %}"
                                     {% if isColumn and hasPreview %}style="width: 40%; min-width: 120px;"{% endif %}>
                                    <div class="p-3 rounded" style="background: rgba(0,0,0,0.15); word-break: break-word; overflow-wrap: break-word;">{{ desc|markdown_to_html }}</div>
                                </div>
                                {% endif %}

                                {% if hasPreview %}
                                <div class="{% if isColumn and hasDesc %}flex-grow-1 min-width-0{% endif %}">
                                    {{ _self.share_preview(share, ds, profile_username) }}
                                </div>
                                {% endif %}

                                {% if hasDesc and (dds == 1 or dds == 3) %}
                                <div class="{% if isColumn and hasPreview %}flex-shrink-0{% endif %} text-light small mt-{% if not isColumn %}3{% else %}0{% endif %}"
                                     {% if isColumn and hasPreview %}style="width: 40%; min-width: 120px;"{% endif %}>
                                    <div class="p-3 rounded" style="background: rgba(0,0,0,0.15); word-break: break-word; overflow-wrap: break-word;">{{ desc|markdown_to_html }}</div>
                                </div>
                                {% endif %}
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

            {% endif %}

            {# ============================================================ #}
            {# Ungrouped Shared Items (old shares)                           #}
            {# ============================================================ #}
            {% if profile_show_shares and profile_shares|length > 0 %}
            <div class="card glass-panel">
                <div class="card-header bg-transparent border-success border-1 border-bottom p-3">
                    <div class="mb-0 d-flex align-items-center flex-wrap gap-2">
                        <span>
                            <i class="mdi mdi-share-variant me-2 text-success opacity-50"></i>
                            <span class="text-cyber">{{ 'cq_contact.detail.shared_items'|trans }}</span>
                        </span>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush bg-transparent">
                        {% for share in profile_shares %}
                        <div class="list-group-item bg-transparent border-secondary border-opacity-25 px-4 py-3">
                            {# Share header row #}
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                                <a href="{{ path('cq_share_access', {username: profile_username, shareUrl: share.share_url}) }}"
                                   class="text-decoration-none">
                                    {% if share.source_type == 'cqmpack' %}
                                        <i class="mdi mdi-graph me-2 text-info"></i>
                                    {% elseif share.preview_type is defined and share.preview_type == 'pdf' %}
                                        <i class="mdi mdi-file-pdf-box me-2 text-danger"></i>
                                    {% else %}
                                        <i class="mdi mdi-file me-2 text-warning"></i>
                                    {% endif %}
                                    <span class="text-light fw-bold">{{ share.title }}</span>
                                    {% if share.source_type == 'cqmpack' %}
                                        <span class="badge bg-info bg-opacity-25 text-info ms-2">{{ 'cq_contact.detail.memory_pack'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-warning bg-opacity-25 text-warning ms-2">{{ 'cq_contact.detail.file'|trans }}</span>
                                    {% endif %}
                                </a>
                                <div class="d-flex align-items-center gap-2">
                                    <small class="text-light opacity-50"><i class="mdi mdi-eye me-1"></i>{{ share.views }} {{ 'cq_contact.detail.views'|trans }}</small>
                                    <button class="btn btn-sm btn-outline-primary border-0 copy-share-url"
                                            data-url="{{ app.request.schemeAndHttpHost }}/{{ profile_username }}/share/{{ share.share_url }}"
                                            title="{{ 'citadel_explorer.copy_link'|trans }}">
                                        <i class="mdi mdi-link-variant"></i>
                                    </button>
                                </div>
                            </div>

                            {# Description + Content preview #}
                            {% set ds = share.display_style|default(1) %}
                            {% set desc = share.description|default('') %}
                            {% set dds = share.description_display_style|default(1) %}
                            {% set hasPreview = profile_show_share_content and share.preview_type is defined and ds > 0 %}
                            {% set hasDesc = desc|trim is not empty %}

                            {% if hasDesc or hasPreview %}
                            {% set isColumn = dds == 2 or dds == 3 %}
                            <div class="mt-3{% if isColumn and hasDesc and hasPreview %} d-flex flex-column flex-md-row gap-3{% endif %}">
                                {% if hasDesc and (dds == 0 or dds == 2) %}
                                <div class="{% if isColumn and hasPreview %}flex-shrink-0{% endif %} text-light small mb-{% if not isColumn %}3{% else %}0{% endif %}"
                                     {% if isColumn and hasPreview %}style="width: 40%; min-width: 120px;"{% endif %}>
                                    <div class="p-3 rounded" style="background: rgba(0,0,0,0.15); word-break: break-word; overflow-wrap: break-word;">{{ desc|markdown_to_html }}</div>
                                </div>
                                {% endif %}

                                {% if hasPreview %}
                                <div class="{% if isColumn and hasDesc %}flex-grow-1 min-width-0{% endif %}">
                                    {{ _self.share_preview(share, ds, profile_username) }}
                                </div>
                                {% endif %}

                                {% if hasDesc and (dds == 1 or dds == 3) %}
                                <div class="{% if isColumn and hasPreview %}flex-shrink-0{% endif %} text-light small mt-{% if not isColumn %}3{% else %}0{% endif %}"
                                     {% if isColumn and hasPreview %}style="width: 40%; min-width: 120px;"{% endif %}>
                                    <div class="p-3 rounded" style="background: rgba(0,0,0,0.15); word-break: break-word; overflow-wrap: break-word;">{{ desc|markdown_to_html }}</div>
                                </div>
                                {% endif %}
                            </div>
                            {% endif %}
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

        </div>
    </div>
</div>

{% if profile_has_photo %}
{# Photo Fullscreen Modal #}
<div class="modal fade" id="profilePhotoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass-panel border-0" style="background: transparent;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title text-cyber"><i class="mdi mdi-account-box me-2"></i>{{ profile_username }}</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center p-4">
                <img src="{{ path('cq_profile_photo', {username: profile_username}) }}?full=1" alt="{{ profile_username }}" 
                     class="rounded border border-2 border-primary img-fluid">
            </div>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('profile-public') }}
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('.copy-profile-url').forEach(btn => {
            btn.addEventListener('click', function() {
                const url = this.dataset.url;
                navigator.clipboard.writeText(url).then(() => {
                    const icon = this.querySelector('i');
                    icon.classList.remove('mdi-content-copy');
                    icon.classList.add('mdi-check', 'text-success');
                    setTimeout(() => {
                        icon.classList.remove('mdi-check', 'text-success');
                        icon.classList.add('mdi-content-copy');
                    }, 2000);
                });
            });
        });
        document.querySelectorAll('.copy-share-url').forEach(btn => {
            btn.addEventListener('click', function() {
                const url = this.dataset.url;
                navigator.clipboard.writeText(url).then(() => {
                    const icon = this.querySelector('i');
                    icon.classList.remove('mdi-link-variant');
                    icon.classList.add('mdi-check', 'text-success');
                    setTimeout(() => {
                        icon.classList.remove('mdi-check', 'text-success');
                        icon.classList.add('mdi-link-variant');
                    }, 2000);
                });
            });
        });
        document.querySelectorAll('.bio-toggle').forEach(link => {
            link.addEventListener('click', function(e) {
                e.preventDefault();
                const container = this.closest('.bio-container');
                const short = container.querySelector('.bio-short');
                const full = container.querySelector('.bio-full');
                const expanded = !full.classList.contains('d-none');
                short.classList.toggle('d-none', !expanded);
                full.classList.toggle('d-none', expanded);
                this.textContent = expanded ? this.dataset.showMore : this.dataset.showLess;
            });
        });
        // Profile photo fullscreen modal — handled via data-bs-toggle/data-bs-target attributes
        // Scroll to content navigation if a specific group was requested via URL
        {% if profile_active_group_slug is defined and profile_active_group_slug is not null %}
        const navEl = document.getElementById('profile-content-nav');
        if (navEl) {
            navEl.scrollIntoView({ behavior: 'instant', block: 'start' });
        }
        {% endif %}
    });
    </script>
{% endblock %}
