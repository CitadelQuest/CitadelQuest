{% extends 'base.html.twig' %}

{% block title %}{{ 'cq_explorer.page_title'|trans }} - {{ parent() }}{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        window.citadelExplorerConfig = {
            translations: {
                explore: '{{ "citadel_explorer.explore"|trans }}',
                loading: '{{ "ui.loading"|trans }}',
                error_loading: '{{ "cq_contact.error_loading"|trans }}',
                no_items: '{{ "cq_contact.detail.no_items"|trans }}',
                download_to_citadel: '{{ "cq_contact.detail.download_to_citadel"|trans }}',
                downloading: '{{ "cq_contact.detail.downloading"|trans }}',
                downloaded: '{{ "cq_contact.detail.downloaded"|trans }}',
                download_failed: '{{ "cq_contact.detail.download_failed"|trans }}',
                download_success: '{{ "cq_contact.detail.download_success"|trans }}',
                memory_pack: '{{ "cq_contact.detail.memory_pack"|trans }}',
                file: '{{ "cq_contact.detail.file"|trans }}',
                views: '{{ "cq_contact.detail.views"|trans }}',
                add_to_library: '{{ "cq_contact.detail.add_to_library"|trans }}',
                ui_view: '{{ "ui.view"|trans }}',
                add_contact: '{{ "cq_contact.add_contact"|trans }}',
                send_friend_request: '{{ "cq_contact.send_friend_request"|trans }}',
                friend_request_sent: '{{ "cq_contact.friend_request_sent"|trans }}',
                already_contact: '{{ "citadel_explorer.already_contact"|trans }}',
                view_contact: '{{ "citadel_explorer.view_contact"|trans }}',
                not_citadelquest: '{{ "citadel_explorer.not_citadelquest"|trans }}',
                profile_not_public: '{{ "citadel_explorer.profile_not_public"|trans }}',
                shared_items: '{{ "cq_contact.detail.shared_items"|trans }}',
                select_library: '{{ "cq_contact.detail.select_library"|trans }}',
                loading_libraries: '{{ "cq_contact.detail.loading_libraries"|trans }}',
                no_libraries: '{{ "cq_contact.detail.no_libraries"|trans }}',
                added_to_library: '{{ "cq_contact.detail.added_to_library"|trans }}',
                select_library_first: '{{ "cq_contact.detail.select_library_first"|trans }}',
                nodes: '{{ "spirit.memory.nodes"|trans }}',
                relationships: '{{ "spirit.memory.relationships"|trans }}',
                show_more: '{{ "ui.show_more"|trans }}',
                show_less: '{{ "ui.show_less"|trans }}',
                copy_link: '{{ "citadel_explorer.copy_link"|trans }}',
                link_copied: '{{ "citadel_explorer.link_copied"|trans }}',
                contact_shared_items: '{{ "citadel_explorer.contact_shared_items"|trans }}',
                follow: '{{ "feed.follow"|trans }}',
                following: '{{ "feed.following"|trans }}',
                follow_success: '{{ "feed.follow_success"|trans }}',
                unfollow_success: '{{ "feed.unfollow_success"|trans }}',
            }
        };
        window.explorerSidebarConfig = {
            translations: {
                following: '{{ "feed.following"|trans }}',
                followers: '{{ "feed.followers"|trans }}',
                contacts: '{{ "cq_contact.page_title"|trans }}',
                no_following: '{{ "feed.no_following"|trans }}',
                no_followers: '{{ "feed.no_followers"|trans }}',
                no_contacts: '{{ "cq_contact.no_contacts"|trans }}',
                friend_request_updated: '{{ "cq_contact.friend_request_updated"|trans }}',
            }
        };
    </script>
    {{ encore_entry_script_tags('citadel-explorer') }}
{% endblock %}

{% block body %}
<div class="container-fluid mt-1 px-md-4">
    <div class="row">
        {# ===== Main Content — CQ Explorer ===== #}
        <div class="col-md-9 col-12">
            <div class="pt-1">
                {# Citadel Explorer — URL input #}
                <div class="mb-4">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text glass-panel"><i class="mdi mdi-earth text-cyber"></i></span>
                        <input type="url" id="explorerUrlInput" class="form-control glass-input"
                               placeholder="{{ 'citadel_explorer.url_placeholder'|trans }}" value="">
                        <button class="btn btn-sm btn-cyber" id="explorerFetchBtn" type="button" disabled>
                            <i class="mdi mdi-magnify me-2"></i><span class="d-none d-md-inline-block">{{ 'citadel_explorer.explore'|trans }}</span>
                        </button>
                    </div>
                    <div class="small text-light opacity-50 ms-2 mt-1" id="explorerUrlHelp">{{ 'citadel_explorer.url_help'|trans }}</div>
                </div>

                {# Citadel Explorer — profile preview container #}
                <div id="explorerPreview" class="d-none mb-5"></div>
            </div>
        </div>

        {# ===== Sidebar — Following / Followers / Contacts ===== #}
        <div class="col-md-3 col-12">
            {# CQ Contacts #}
            <div class="mb-3 glass-panel p-2">
                <div class="d-flex align-items-center mb-2 px-1 cursor-pointer" data-sidebar-toggle="contacts">
                    <i class="mdi mdi-account-multiple me-2 text-success"></i>
                    <span class="small fw-bold text-light opacity-75">{{ 'cq_contact.page_title'|trans }}</span>
                    <span class="badge bg-success bg-opacity-25 text-success ms-auto" id="sidebarContactsCount">0</span>
                    <i class="mdi mdi-chevron-down ms-2 text-muted small sidebar-chevron"></i>
                </div>
                <div id="sidebarContactsList" style="max-height: 350px; overflow-y: auto;">
                    <div class="text-center py-2"><i class="mdi mdi-loading mdi-spin text-cyber small"></i></div>
                </div>
            </div>

            {# Following #}
            <div class="mb-3 glass-panel p-2">
                <div class="d-flex align-items-center mb-2 px-1 cursor-pointer" data-sidebar-toggle="following">
                    <i class="mdi mdi-rss me-2 text-warning"></i>
                    <span class="small fw-bold text-light opacity-75">{{ 'feed.following'|trans }}</span>
                    <span class="badge bg-warning bg-opacity-25 text-warning ms-auto" id="sidebarFollowingCount">0</span>
                    <i class="mdi mdi-chevron-down ms-2 text-muted small sidebar-chevron"></i>
                </div>
                <div id="sidebarFollowingList" style="max-height: 280px; overflow-y: auto;">
                    <div class="text-center py-2"><i class="mdi mdi-loading mdi-spin text-cyber small"></i></div>
                </div>
            </div>

            {# Followers #}
            <div class="mb-3 glass-panel p-2">
                <div class="d-flex align-items-center mb-2 px-1 cursor-pointer" data-sidebar-toggle="followers">
                    <i class="mdi mdi-account-group me-2 text-info"></i>
                    <span class="small fw-bold text-light opacity-75">{{ 'feed.followers'|trans }}</span>
                    <span class="badge bg-info bg-opacity-25 text-info ms-auto" id="sidebarFollowersCount">0</span>
                    <i class="mdi mdi-chevron-down ms-2 text-muted small sidebar-chevron"></i>
                </div>
                <div id="sidebarFollowersList" style="max-height: 280px; overflow-y: auto;">
                    <div class="text-center py-2"><i class="mdi mdi-loading mdi-spin text-cyber small"></i></div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Contact Detail Modal -->
<div class="modal fade" id="contactDetailModal" tabindex="-1" aria-labelledby="contactDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content glass-panel">
            <div class="modal-header">
                <h5 class="modal-title" id="contactDetailModalLabel">
                    <i class="mdi mdi-account-details me-2 text-cyber"></i>{{ 'cq_contact.contact_details'|trans }}
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="contactDetailContent">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

<!-- Delete Contact Confirmation Modal -->
<div class="modal fade" id="deleteContactModal" tabindex="-1" aria-labelledby="deleteContactModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content glass-panel">
            <div class="modal-header bg-danger">
                <span class="modal-title text-white" id="deleteContactModalLabel">
                    <i class="mdi mdi-account-minus me-2"></i>{{ 'cq_contact.delete_contact'|trans }}
                </span>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="text-center mb-3">
                    <i class="mdi mdi-alert-triangle text-warning fs-1"></i>
                </div>
                <p class="text-center">{{ 'cq_contact.delete_confirm_message'|trans }}</p>
                <p class="text-muted small text-center">{{ 'cq_contact.delete_info'|trans }}</p>
            </div>
            <div class="modal-footer justify-content-between">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="mdi mdi-cancel me-2"></i>{{ 'ui.cancel'|trans }}
                </button>
                <button type="button" class="btn btn-danger" id="confirmDeleteContact">
                    <i class="mdi mdi-delete me-2"></i>{{ 'ui.delete'|trans }}
                </button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Delete contact handler (used by delete confirmation modal)
    function deleteContact(contactId) {
        fetch('/api/cq-contact/' + contactId, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(response => response.json())
        .then(data => {
            if (data) {
                window.toast.success('{{ "cq_contact.contact_deleted"|trans }}');
                // Refresh sidebar contacts
                if (window.explorerSidebar) {
                    window.explorerSidebar.loadContacts().then(() => {
                        window.explorerSidebar.renderContactsSidebar();
                    });
                }
                document.querySelector('#deleteContactModal [data-bs-dismiss="modal"]').click();
            } else {
                window.toast.error(data.message || '{{ "cq_contact.error_deleting"|trans }}');
            }
        })
        .catch(error => {
            console.error('Error deleting contact:', error);
            window.toast.error('{{ "cq_contact.error_deleting"|trans }}');
        });
    }

    // Delete confirmation button
    document.getElementById('confirmDeleteContact').addEventListener('click', function() {
        const contactId = this.dataset.contactId;
        if (contactId) deleteContact(contactId);
    });

    // Expose loadContacts globally so CitadelExplorer can refresh after adding contact
    window.loadContacts = function() {
        if (window.explorerSidebar) {
            window.explorerSidebar.loadContacts().then(() => {
                window.explorerSidebar.renderContactsSidebar();
            });
        }
    };
});
</script>
{% endblock %}
