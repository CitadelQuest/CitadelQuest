{#
    Lightweight base template for public (unauthenticated) pages.
    No Spirit Chat, CQ Chat, notifications, toast, theme service, or loading ghost.
    Used by: CQ Profile public page.
#}
<!DOCTYPE html>
<html{% block html_attributes %}{% endblock %}>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{% endblock %}</title>
        
        {# Favicon #}
        <link rel="apple-touch-icon" sizes="180x180" href="{{ path('cq_profile_photo', {username: profile_username}) }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ path('cq_profile_photo', {username: profile_username}) }}?icon=1">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ path('cq_profile_photo', {username: profile_username}) }}?icon=1">
        <meta name="theme-color" content="#0a0b14">

        {% block stylesheets %}
            {{ encore_entry_link_tags('app-public') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app-public') }}
        {% endblock %}
    </head>
    <body class="position-relative min-vh-100 citadel-background pt-0">

        <main class="pb-5_">
            {% block body %}{% endblock %}
        </main>

        <footer class="footer py-1 position-fixed bottom-0 start-0 end-0" style="z-index: 1020;">
            <div class="container">
                <small class="d-flex align-items-center justify-content-center">
                    <a href="https://www.citadelquest.com/" target="_blank" title="CitadelQuest" style="display:contents;">
                    <img src="{{ asset('build/images/favicon-16x16.png') }}" title="CitadelQuest" />
                    <span class="text-cyber me-1">{{ 'app.name'|trans }}</span>
                    </a>
                    <span>{{ 'app.footer.version'|trans({'%version%': citadel_version}) }}, {{ date('now')|date('Y') }}</span>
                    <span class="text-cyber mx-1">&bull;</span> 
                    <span class="d-inline-block">{{ 'app.footer.made_with_love'|trans|raw }}</span>
                </small>
            </div>
        </footer>

    </body>
</html>
