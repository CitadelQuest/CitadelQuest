{% if app.user %}
<div class="modal fade" id="spiritChatModal" tabindex="-1" aria-labelledby="spiritChatModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-fullscreen">
        <div class="modal-content glass-panel_" style="background-color: #2e3135;">
            <div class="modal-header bg-cyber-g border-success py-2 py-md-3">
                <span id="spiritChatToolsAndConversationsToggle">
                <span class="btn btn-outline-cyber btn-sm me-3 cursor-pointer fs-5 opacity-50"><i class="mdi mdi-menu-open"></i></span>
                
                <span id="spiritChatModalTitle" class="fs-6 me-4"></span></span>
                <span class="modal-title small d-flex align-items-center text-light me-2" id="spiritChatModalLabel">
                    {# {{ 'spirit.chat.title'|trans }}  #}
                    <div class="spirit-icon me-2">
                        <i class="mdi mdi-ghost spiritChatButtonIcon"></i>
                    </div>
                    <span class="spiritName opacity-75"></span>
                </span>
                
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.close'|trans }}"></button>
            </div>
            <div class="modal-body pt-0">
                <div id="spiritChatToolsAndConversations" class="d-none row position-fixed start-0 end-0 bg-dark glow-cyber p-4 border-bottom-1 border-success border-opacity-50" style="z-index: 10;">
                    <div class="col-md-8_ px-0">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="d-none d-md-inline">
                                <i class="mdi mdi-forum-outline text-cyber me-2"></i>
                                <span>{{ 'spirit.chat.conversations'|trans }}</span>
                            </h6>
                            <div class="input-group w-auto mx-2">
                                <span class="input-group-text border-secondary border-opacity-50" style="background-color: transparent;"><i class="mdi mdi-magnify text-secondary"></i></span>
                                <input type="text" class="form-control" id="conversationSearch" placeholder="{{ 'spirit.chat.search_conversations'|trans }}">
                            </div>
                            <button id="newConversationBtn" class="btn btn-sm btn-cyber">
                                <i class="mdi mdi-message-plus"></i><span class="ms-2 d-inline">{{ 'spirit.chat.new_conversation'|trans }}</span>
                            </button>
                        </div>
                        <div id="conversationsList" class="list-group conversation-list">
                            <div class="text-center p-3">
                                <div class="spinner-border text-cyber" role="status">
                                    <span class="visually-hidden">{{ 'auth.key_generation.loading'|trans }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div id="chatContainer" class="chat-container d-none">
                    <div id="chatMessages" class="chat-messages mb-3">
                        <div class="text-center p-3 loading-indicator">
                            <div class="spinner-border text-cyber" role="status">
                                <span class="visually-hidden">{{ 'auth.key_generation.loading'|trans }}</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
                
            {# Context window usage indicator #}
            <div id="contextWindowUsage" class="w-100 m-0 p-0" title="{{ 'spirit.chat.context_window_usage'|trans|default('Context window usage') }}">
                <div id="contextWindowUsageBar" class="bg-cyber rounded opacity-75" style="width: 0%; height: 2px; transition: width 0.3s ease;"></div>
            </div>

            <div class="modal-footer chat-container border-secondary border-opacity-50 pb-3">
                <form id="chatForm" class="d-flex flex-column w-100 m-0">

                    <div>
                        {# Hidden image upload input #}
                        <input type="file" id="imageUpload" accept="*" class="d-none" multiple>
                        {# image upload preview #}
                        <div id="imageUploadPreview" class="w-100 p-2 pt-0 d-none">
                        </div>
                    </div>

                    <div class="d-flex align-items-top gap-2">

                        <div class="d-flex flex-column gap-4 text-end pt-1">                        
                            <button type="button" id="imageUploadButton" class="btn btn-cyber" title="{{ 'file_browser.upload'|trans }}">
                                <i class="mdi mdi-file-plus"></i>
                            </button>

                            <div class="d-flex gap-2 justify-content-end">
                                <i class="mdi mdi-tune-vertical text-cyber cursor-pointer me-1 fs-5" id="chatSettingsIcon" title="{{ 'spirit.chat.settings'|trans|default('Chat Settings') }}"></i>
                            </div>
                        </div>

                        <div class="d-flex flex-column gap-2" style="flex-grow: 1;"> 
                            <textarea id="messageInput" class="form-control flex-grow-1" rows="4" placeholder="{{ 'spirit.chat.type_message'|trans }}" autocomplete="off" focus></textarea>

                            <div class="d-none flex-column gap-1 align-items-center mt-2 ps-2">
                                {# Hidden sliders — values managed by Chat Settings modal #}
                                <input type="hidden" id="responseMaxOutputSlider" value="500">
                                <span id="responseMaxOutputValue" class="d-none">500</span>
                                <input type="hidden" id="responseTemperatureSlider" value="0.7">
                                <span id="responseTemperatureValue" class="d-none">0.7</span>
                            </div>
                        </div>
                        
                        <div class="d-flex flex-column gap-1 pt-1"> 
                            <button type="submit" id="sendMessageBtn" class="btn btn-cyber" style="max-height: min-content !important; padding: 0.4rem 1.2rem !important;">
                                <i class="mdi mdi-message-check"></i>
                            </button>
                            
                            <button type="button" id="stopExecutionBtn" class="btn btn-outline-danger d-none" style="max-height: min-content !important; padding: 0.4rem 1.2rem !important;" title="Stop execution">
                                <i class="mdi mdi-stop-circle"></i>
                            </button>

                            <div id="creditIndicator" class="d-flex gap-2 align-items-center">                           
                            </div>

                            <button type="button" id="extractMemoryBtn" class="btn btn-sm p-0 mt-1 btn-outline-secondary d-none" style="padding: 0 !important;" title="{{ 'spirit.chat.extract_memory'|trans|default('Extract memory from this conversation') }}">
                                <i class="mdi mdi-graph text-info"></i>
                            </button>
                        </div>

                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="newConversationModal" tabindex="-1" aria-labelledby="newConversationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content glass-panel">
            <div class="modal-header bg-cyber-g border-success">
                <h5 class="modal-title" id="newConversationModalLabel"><i class="mdi mdi-message-plus me-2"></i> {{ 'spirit.chat.new_conversation'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.close'|trans }}"></button>
            </div>
            <div class="modal-body">
                <form id="newConversationForm">
                    <div class="mb-3 w-100">
                        <label for="conversationTitle" class="form-label">{{ 'spirit.chat.conversation_title'|trans }}</label>
                        <input type="text" class="form-control" id="conversationTitle" required focus>
                    </div>
                    
                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal"><i class="mdi mdi-close me-2"></i>{{ 'ui.cancel'|trans }}</button>
                        <button type="submit" class="btn btn-cyber"><i class="mdi mdi-check me-2"></i>{{ 'ui.create'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="deleteConversationModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-panel">
            <div class="modal-header bg-danger">
                <i class="mdi mdi-message-alert me-2"></i> <span class="modal-title text-white" id="deleteConversationModalLabel"></span>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.close'|trans }}"></button>
            </div>
            <div class="modal-body">
                <form id="deleteConversationForm">
                    <div class="mb-3 w-100 py-2 text-center fs-5">
                        <span>{{ 'spirit.chat.delete_conversation_confirm'|trans }}</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal" id="deleteConversationModalCancel"><i class="mdi mdi-close me-2"></i>{{ 'ui.cancel'|trans }}</button>
                        <button type="submit" class="btn btn-danger" id="deleteConversationModalSubmit"><i class="mdi mdi-delete me-2"></i>{{ 'ui.delete'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="extractMemoryModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content glass-panel">
            <div class="modal-header bg-info bg-opacity-25 border-info">
                <i class="mdi mdi-graph me-2 text-info"></i> <span class="modal-title text-light">{{ 'spirit.chat.extract_memory'|trans|default('Extract Memory') }}</span>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.close'|trans }}"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3 w-100 py-2 text-center">
                    <p class="mb-2"><i class="mdi mdi-brain text-info me-1"></i> {{ 'spirit.chat.extract_memory_confirm'|trans|default('Memory will be extracted from this conversation.') }}</p>
                    <p class="small text-warning mb-0"><i class="mdi mdi-lock-outline me-1"></i> {{ 'spirit.chat.extract_memory_close_warning'|trans|default('Conversation will be closed after extraction.') }}</p>
                </div>

                {# Max Depth slider #}
                <div class="mb-3">
                    <label class="form-label small text-secondary d-flex justify-content-between">
                        <span>
                            <i class="mdi mdi-layers-triple me-1"></i>
                            {{ 'spirit.memory.extract_panel.max_depth'|trans }}
                        </span>
                        <span id="extract-modal-depth-value" class="badge fw-normal bg-secondary bg-opacity-25">2</span>
                    </label>
                    <input type="range" class="form-range-input w-100" id="extract-modal-depth" min="1" max="3" value="2">
                    <div class="d-flex justify-content-between small text-secondary">
                        <span>1 ({{ 'spirit.memory.extract_panel.depth_fast'|trans }})</span>
                        <span>3 ({{ 'spirit.memory.extract_panel.depth_deep'|trans }})</span>
                    </div>
                </div>

                {# Auto-analyze toggle #}
                <div class="form-check form-switch mb-3">
                    <input class="form-check-input" type="checkbox" role="switch" id="extract-modal-auto-analyze" checked>
                    <label class="form-check-label small text-secondary" for="extract-modal-auto-analyze">
                        <i class="mdi mdi-graph me-1 text-cyber opacity-50"></i>{{ 'spirit.memory.extract_panel.auto_analyze_label'|trans }}
                    </label>
                </div>

                <div class="d-flex justify-content-between">
                    <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal"><i class="mdi mdi-close me-2"></i>{{ 'ui.cancel'|trans }}</button>
                    <button type="button" class="btn btn-cyber" id="extractMemoryConfirmBtn"><i class="mdi mdi-graph me-2"></i>{{ 'spirit.chat.extract_memory_start'|trans|default('Extract Memory') }}</button>
                </div>
            </div>
        </div>
    </div>
</div>

{# Chat Settings modal #}
<div class="modal fade" id="chatSettingsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content glass-panel bg-dark border-1 border-secondary border-opacity-25">
            <div class="modal-header bg-cyber-g border-1 border-secondary border-opacity-25 py-2">
                <h6 class="modal-title"><i class="mdi mdi-tune-vertical me-2"></i>{{ 'spirit.chat.settings'|trans|default('Chat Settings') }}</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'ui.close'|trans }}"></button>
            </div>
            <div class="modal-body">
                {# chatInfo AI Model #}
                <div class="mb-5">
                    <div class="d-flex align-items-center gap-2">
                        <i class="mdi mdi-brain text-cyber"></i>
                        <span id="chatInfoPrimaryAiModel" class="small d-flex w-100 justify-content-between" title="{{ 'settings.ai.models.primary'|trans|default('Primary AI Model') }}">-</span>
                    </div>
                    <div class="d-flex_ d-none align-items-center gap-2">
                        <i class="mdi mdi-image-edit-outline text-cyber"></i>
                        <span id="_chatInfoSecondaryAiModel" class="small" title="{{ 'settings.ai.models.secondary'|trans|default('Image gen/edit AI Model') }}">-</span>
                    </div>
                </div>

                {# Temperature slider #}
                <div class="mb-5">
                    <label class="form-label all d-flex justify-content-between align-items-center" for="chatSettingsTemperature">
                        <span><i class="mdi mdi-thermometer text-cyber me-1"></i> {{ 'spirit.chat.response_temperature'|trans|default('Temperature') }}</span>
                        <span id="chatSettingsTemperatureValue" class="badge fw-normal bg-secondary bg-opacity-25">0.7</span>
                    </label>
                    <input type="range" class="form-range-input w-100" id="chatSettingsTemperature" min="0" max="1" value="0.7" step="0.1">
                    <div class="d-flex justify-content-between small text-secondary mt-1 mx-2">
                        <span>0 ({{ 'spirit.chat.temperature_precise'|trans|default('Precise') }})</span>
                        <span>1 ({{ 'spirit.chat.temperature_creative'|trans|default('Creative') }})</span>
                    </div>
                </div>

                {# Memory Type select #}
                <div class="mb-5">
                    <div class="d-flex align-items-center justify-content-between">
                        <label for="chatSettingsMemoryType" class="form-label mb-0">
                            <i class="mdi mdi-memory text-cyber me-1"></i> {{ 'spirit.memory.type'|trans|default('Spirit Memory Type') }}
                        </label>
                        <select class="form-select form-select-sm bg-dark bg-opacity-50 text-light border-secondary" 
                                id="chatSettingsMemoryType" style="width: auto; min-width: 180px;">
                            <option value="0">🚫 {{ 'spirit.memory.type_none'|trans|default('No Memory') }}</option>
                            <option value="1">🧠 {{ 'spirit.memory.type_reflexes'|trans|default('Reflexes') }}</option>
                            <option value="2">🤖 {{ 'spirit.memory.type_agent'|trans|default('Memory Agent') }}</option>
                        </select>
                    </div>
                    <div id="chatSettingsMemoryTypeInfo" class="mt-2 mx-4 small text-secondary"></div>
                </div>

                {# AI Tools Data Optimization toggle #}
                <div class="mb-4">
                    <div class="d-flex align-items-center justify-content-between">
                        <label for="chatSettingsAiToolsDataOptimization" class="form-label mb-0">
                            <i class="mdi mdi-broom text-cyber me-1"></i> {{ 'spirit.chat.ai_tools_data_optimization'|trans|default('AI Tools Data Optimization') }}
                        </label>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch" id="chatSettingsAiToolsDataOptimization">
                        </div>
                    </div>
                    <div class="mt-2 mx-4 small text-secondary">
                        <i class="mdi mdi-information-outline me-1"></i>
                        {{ 'spirit.chat.ai_tools_data_optimization_info'|trans|default('Replaces outdated tool call data from previous turns with a placeholder before sending to AI. Keeps tool-call structure intact. Reduces tokens & context noise when Spirit re-reads/updates files.') }}
                    </div>
                </div>
                
                {# AI Tools toggle + list #}
                <div>
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <label class="form-label mb-0">
                            <i class="mdi mdi-tools text-cyber me-1"></i> {{ 'spirit.tabs.ai_tools'|trans|default('AI Tools') }}
                        </label>
                        <div class="form-check form-switch mb-0">
                            <input class="form-check-input" type="checkbox" role="switch" id="chatSettingsIncludeTools" checked>
                        </div>
                    </div>
                    <div id="chatSettingsToolsList" class="d-flex flex-column gap-1">
                        <div class="text-center p-3">
                            <div class="spinner-border spinner-border-sm text-cyber" role="status"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between border-secondary border-opacity-25">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">
                    <i class="mdi mdi-close me-1"></i>{{ 'ui.cancel'|trans }}
                </button>
                <button type="button" class="btn btn-sm btn-cyber" id="chatSettingsSaveBtn">
                    <i class="mdi mdi-content-save me-1"></i>{{ 'ui.save'|trans|default('Save') }}
                </button>
            </div>
        </div>
    </div>
</div>

{# Content showcase modal - full-screen modal for all (text, md, pdf, image, audio, video) content viewing #}
<div class="modal fade" id="contentShowcaseModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered modal-fullscreen">
        <div class="modal-content bg-dark">
            <div class="modal-header border-success_border-bottom border-0 py-2">
                <h6 class="modal-title" id="contentShowcaseModalLabel"><i class="" id="contentShowcaseModalHeaderIcon"></i> <span id="contentShowcaseModalTitle"></span></h6>
            </div>
            <div class="modal-body position-relative">
                <i class="mdi mdi-close text-cyber bg-dark bg-opacity-75 rounded p-1 cursor-pointer position-fixed end-0 top-0 me-1 fs-5" style="z-index: 1;" 
                    data-bs-dismiss="modal" aria-label="{{ 'ui.close'|trans }}" title="{{ 'ui.close'|trans }}"></i>
                <div class="contentShowcaseModal-content w-100 h-100 position-relative">
                </div>
            </div>
            <div class="modal-footer d-flex justify-content-between d-none">
                <button type="button" class="btn btn-secondary me-2" data-bs-dismiss="modal"><i class="mdi mdi-close me-2"></i>{{ 'ui.close'|trans }}</button>
                <button type="button" class="btn btn-cyber"><i class="mdi mdi-download me-2"></i>{{ 'file_browser.download'|trans }}</button>
            </div>
        </div>
    </div>
</div>
{% endif %}
